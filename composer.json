{
  "name": "law4devs/law4devs",
  "description": "Official PHP SDK for the Law4Devs EU Regulatory Compliance API",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "law4devs",
      "email": "sdk@law4devs.eu",
      "homepage": "https://law4devs.eu"
    }
  ],
  "keywords": ["law4devs", "eu", "regulatory", "compliance", "gdpr", "cra", "nis2", "ai-act"],
  "homepage": "https://law4devs.eu",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Law4Devs\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Law4Devs\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "support": {
    "docs": "https://docs.law4devs.eu/sdks/php",
    "issues": "https://github.com/law4devs/law4devs-php-pub/issues"
  }
}
